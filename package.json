{
  "name": "pixelati",
  "version": "0.1.1",
  "description": "Turn any image into truecolor terminal art using half-block characters.",
  "type": "module",
  "bin": {
    "pixelati": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "pixelati": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "terminal",
    "ansi",
    "image",
    "ascii-art",
    "cli",
    "truecolor",
    "half-block"
  ],
  "author": "DMXL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DMXL/pixelati.git"
  },
  "homepage": "https://github.com/DMXL/pixelati#readme",
  "bugs": {
    "url": "https://github.com/DMXL/pixelati/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
